cat > /home/claude/new-gitignore.txt << 'EOF'
# === Python ===
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# === 日志文件 ===
*.log
logs/

# === Terraform ===
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl
# tfvars 含敏感信息，不上传
*.tfvars

# === 环境变量 ===
.env
.env.*

# === 系统文件 ===
.DS_Store
Thumbs.db
Icon*

# === 编辑器 ===
.vscode/
.idea/
EOF
echo "done"